FLASK_ENV=production
FLASK_SECRET_KEY=change-me-in-production

# Thermodrucker hängt per USB am Pi.
# Standard: /dev/usb/lp0 (erster USB-Drucker am Kernel-usblp-Treiber).
# Wenn data/printers.json existiert, hat diese Vorrang; PRINTER_DEVICE
# wird dann nur als Fallback genutzt.
PRINTER_DEVICE=/dev/usb/lp0

# Bind-Adresse des Flask-Servers auf dem Raspberry Pi
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Admin-Passwort für DB-Reset auf der Übersichts-Seite.
# Leer lassen, um den Reset-Endpoint zu deaktivieren.
ADMIN_PASSWORD=change-me-please
